{
  "name": "doom-macos",
  "version": "1.0.0",
  "description": "Doom Demo - macOS Edition with Electron and Swift",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:react\" \"wait-on http://localhost:3000 && pnpm dev:electron\"",
    "dev:react": "vite --port 3000",
    "dev:electron": "electron .",
    "build": "pnpm build:react && pnpm build:electron",
    "build:react": "vite build",
    "build:electron": "tsc src/main.ts --outDir dist --module commonjs --target es2020 --skipLibCheck",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac",
    "dist:dmg": "electron-builder --mac dmg",
    "dist:app": "electron-builder --mac dir",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "electron-is-dev": "^3.0.1",
    "typescript": "^5.9.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.doom.macos",
    "productName": "Doom",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "publish": null
}
